# =============================================================================
# Catalog Service — Environment Variables
# =============================================================================
# Copy to .env in this directory:
#   cp .env.example .env
# =============================================================================

# Server
SERVER_PORT=8082
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_NAME=catalog-service
SERVER_ENV=development
SERVER_GRACEFUL_TTL=30
SERVER_LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=nova_catalog
DB_PASSWORD=secret
DB_NAME=catalog_db
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_CONN_TIMEOUT=5s
DB_CONN_MAX_LIFETIME=300s
# Optional full DSN override:
# DATABASE_DSN=postgres://nova:nova_dev_password@localhost:5433/catalog_db?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
# Optional full address override:
# REDIS_ADDR=localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=catalog-service
KAFKA_GROUP_ID=catalog-service
KAFKA_CONSUME_TOPICS=user-events

# OpenTelemetry (set TELEMETRY_ENABLED=true when an OTLP collector is running)
TELEMETRY_ENABLED=false
TELEMETRY_OTLP_ENDPOINT=localhost:4317
TELEMETRY_SERVICE_NAME=catalog-service

# HTTP / CORS
HTTP_CORS_ALLOW_ORIGINS=*
