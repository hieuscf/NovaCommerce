# =============================================================================
# Identity Service — Environment Variables
# =============================================================================
# Copy to .env in this directory:
#   cp .env.example .env
# =============================================================================

# Server
SERVER_PORT=8081
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_NAME=identity-service
SERVER_ENV=development
SERVER_GRACEFUL_TTL=30
SERVER_LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=nova_identity
DB_PASSWORD=secret
DB_NAME=identity_db
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_CONN_TIMEOUT=5s
DB_CONN_MAX_LIFETIME=300s
# Optional full DSN override:
# DATABASE_DSN=postgres://nova:nova_dev_password@localhost:5433/identity_db?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
# Optional full address override:
# REDIS_ADDR=localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=identity-service
KAFKA_GROUP_ID=identity-service

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_ISSUER=novacommerce-identity
JWT_REFRESH_TTL=168h

# Email
EMAIL_FROM=noreply@novacommerce.com
EMAIL_SENDGRID_API_KEY=

# Rate Limit
# Set MAX=0 to disable rate limiting (local dev / Postman). Production: use 5 / 10.
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=15m
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW=1h

# OpenTelemetry (set TELEMETRY_ENABLED=true when an OTLP collector is running)
TELEMETRY_ENABLED=false
TELEMETRY_OTLP_ENDPOINT=localhost:4317
TELEMETRY_SERVICE_NAME=identity-service

# HTTP / CORS
HTTP_CORS_ALLOW_ORIGINS=*

# OAuth2 — Google (register at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8081/auth/oauth/google/callback

# OAuth2 — Facebook (register at https://developers.facebook.com)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL=http://localhost:8081/auth/oauth/facebook/callback
