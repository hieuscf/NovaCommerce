# =============================================================================
# Identity Service — Environment Variables
# =============================================================================
# Copy to .env in this directory or export before running locally:
#   cp .env.example .env
# =============================================================================

# Application
APP_NAME=identity-service
APP_ENV=development
APP_PORT=8081
APP_GRACEFUL_TTL=30
APP_LOG_LEVEL=info

# PostgreSQL (identity_db created by infrastructure/docker-compose/scripts/dev-init.sh)
DATABASE_DSN=postgres://nova:nova_dev_password@localhost:5433/identity_db?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=300

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=identity-service

# JWT (keys generated in SVC-IS-003)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=7

# OpenTelemetry
TELEMETRY_OTLP_ENDPOINT=localhost:4317
TELEMETRY_SERVICE_NAME=identity-service

# HTTP / CORS
HTTP_CORS_ALLOW_ORIGINS=*
