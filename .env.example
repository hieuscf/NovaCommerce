# =============================================================================
# NovaCommerce — Local Development Environment Variables
# =============================================================================
# Copy this file to the repo root as `.env` before starting infrastructure:
#
#   cp .env.example .env
#   cd infrastructure/docker-compose && docker compose --env-file ../../.env up -d
#
# Or run from repo root:
#   make dev-up
# =============================================================================

COMPOSE_PROJECT_NAME=nova

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Service databases (created by scripts/dev-init.sh)
# identity_db, catalog_db, commerce_db, fulfillment_db,
# engagement_db, notification_db, file_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
# -----------------------------------------------------------------------------
# Zookeeper
# -----------------------------------------------------------------------------
ZOOKEEPER_PORT=2181
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_PORT=9092
KAFKA_CLUSTER_NAME=
KAFKA_UI_PORT=8090
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1

# -----------------------------------------------------------------------------
# Elasticsearch / Kibana
# -----------------------------------------------------------------------------
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
ES_JAVA_OPTS="-Xms512m -Xmx512m"
# Elasticsearch index name (created by dev-init.sh)
ELASTICSEARCH_PRODUCTS_INDEX=products

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_PORT=6333
QDRANT_PRODUCTS_COLLECTION=products
QDRANT_VECTOR_SIZE=1536

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Buckets created by dev-init.sh: nova-bronze, nova-silver, nova-gold, nova-uploads

# -----------------------------------------------------------------------------
# ClickHouse
# -----------------------------------------------------------------------------
CLICKHOUSE_DB=nova_analytics
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9009

# -----------------------------------------------------------------------------
# Dev tools (docker-compose.override.yml)
# -----------------------------------------------------------------------------
ADMINER_PORT=8888
REDIS_COMMANDER_PORT=8889

# -----------------------------------------------------------------------------
# Microservice ports (for local Go/frontend apps — not used by compose stack)
# -----------------------------------------------------------------------------
API_GATEWAY_PORT=8080
IDENTITY_SERVICE_PORT=8081
CATALOG_SERVICE_PORT=8082
COMMERCE_SERVICE_PORT=8083
FULFILLMENT_SERVICE_PORT=8084
ENGAGEMENT_SERVICE_PORT=8085
DISCOVERY_SERVICE_PORT=8086
